###############################################################################
#  STEALTHNET — 部署环境变量模板
#  复制为 .env 后修改
#  cp .env.example .env
###############################################################################

# ── 域名（必填）────────────────────────────────────────────────────
DOMAIN=web.coolgo.network,webapp.coolgo.cloud

# ── GitHub Container Registry 镜像前缀 ─────────────────────────────
# 格式: ghcr.io/<owner>/stealthnet
# 如果你 fork 了仓库，改成你自己的
GHCR_IMAGE_PREFIX=ghcr.io/mikimiya/remnawave-STEALTHNET-Bot
IMAGE_TAG=latest

# ── PostgreSQL ────────────────────────────────────────────────────
POSTGRES_DB=stealthnet
POSTGRES_USER=stealthnet
POSTGRES_PASSWORD=CoolgoNetwork@2024!

# ── JWT ───────────────────────────────────────────────────────────
# 至少 32 字符的随机字符串，可用: openssl rand -hex 32
JWT_SECRET=26a7c88039c85fed89d146662fff0cc824788e052e109bcb2ea114188df18e2c
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── 初始管理员 ────────────────────────────────────────────────────
INIT_ADMIN_EMAIL=admin@coolgo.network
INIT_ADMIN_PASSWORD=Admin@CoolGo2026

# ── Remnawave 面板（可选）─────────────────────────────────────────
REMNA_API_URL=https://panel.coolgo.network
REMNA_ADMIN_TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ1dWlkIjoiYTYyNmRjYzYtODFjZi00NWY4LWE4OTQtZjUwNDUzMGI0ZDllIiwidXNlcm5hbWUiOm51bGwsInJvbGUiOiJBUEkiLCJpYXQiOjE3NjY5ODc1MTIsImV4cCI6MTA0MDY5MDExMTJ9.1H5q8O24dPV9U6qMenCY7K6BvNTu3DHzV28pzII9OPY


# ── Telegram Bot ──────────────────────────────────────────────────
BOT_TOKEN=8711041182:AAFhmYAaJLkarGo-dddddddddddd
API_URL=http://api:5000    

# ── 前端静态文件路径（Caddy 使用）─────────────────────────────────
FRONTEND_DIST=/var/www/stealthnet
