# ── 环境变量 ──────────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ── Node.js 依赖 ──────────────────────────────────────────────────
node_modules/
**/node_modules/

# ── 前端构建产物 ──────────────────────────────────────────────────
frontend/dist/
frontend/.vite/
frontend/coverage/

# ── TypeScript 编译产物 ───────────────────────────────────────────
backend/dist/
bot/dist/
**/*.js.map
**/*.d.ts.map

# ── Nginx 生成配置（由 install.sh 根据域名动态生成）──────────────
nginx/nginx.conf

# ── SSL 证书（敏感文件，不提交）──────────────────────────────────
nginx/ssl/
certbot/

# ── Docker 数据卷 / 运行时数据 ────────────────────────────────────
postgres-data/
data/

# ── 日志文件 ──────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── 编辑器 / IDE ──────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── 测试覆盖率 ────────────────────────────────────────────────────
coverage/
.nyc_output/

# ── 临时文件 ──────────────────────────────────────────────────────
*.tmp
*.temp
.cache/
